{
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["no-unused-vars", "ban-ts-comment", "no-var"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true
  }
}
